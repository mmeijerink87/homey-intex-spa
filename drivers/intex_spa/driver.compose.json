    "target_temperature": {
      "min": 20,
      "max": 40,
      "step": 1
    },
    "measure_temperature": {
      "decimals": 0
    }
  },
  "images": {
    "small": "/drivers/intex_spa/assets/images/small.png",
    "large": "/drivers/intex_spa/assets/images/large.png"
  },
  "connectivity": [
    "lan"
  ],
  "pair": [
    {
      "id": "list_devices",

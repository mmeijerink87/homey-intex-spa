{
  "name": {
    "en": "Intex PureSpa",
    "nl": "Intex PureSpa"
  },
  "class": "thermostat",
  "capabilities": [
    "measure_power",
    "measure_temperature",
    "target_temperature",
    "intex_spa_filter",
    "intex_spa_heater",
    "intex_spa_bubbles",
    "intex_spa_power"
  ],

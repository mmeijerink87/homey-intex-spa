      "value": "192.168.1.100"
    },
    {
      "id": "port",
      "type": "number",
      "label": {
        "en": "Port",
        "nl": "Poort"
      },
      "value": 8990
    },
    {
      "id": "poll_interval",
      "type": "number",
      "label": {
        "en": "Poll interval (seconds)",
        "nl": "Polling interval (seconden)"

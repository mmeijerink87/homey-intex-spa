        "next": "add_devices"
      },
      "options": {
        "singular": true
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "settings": [
    {
      "id": "ip",
      "type": "text",
      "label": {
        "en": "IP Address",
        "nl": "IP-adres"
